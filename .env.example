# ── LLM (NVIDIA OpenAI-compatible endpoint) ───────────────────────────────────
# Get API key from NVIDIA Integrate:
# https://build.nvidia.com/
NVIDIA_API_KEY=your_nvidia_api_key_here
LLM_BASE_URL=https://integrate.api.nvidia.com/v1
LLM_MODEL=minimaxai/minimax-m2.5
LLM_TOP_P=0.95
LLM_MAX_TOKENS=8192
JOB_EMBEDDING_MODEL=minilm
JOB_PROCESSING_CONCURRENCY=4
JOB_PROCESSING_BACKGROUND=true
JOB_PROCESSING_QUEUE_POLL_SECONDS=5
JOB_PROCESSING_QUEUE_BATCH_SIZE=10
JOB_PROCESSING_RETRY_DELAY_SECONDS=60
JOB_PROCESSING_MAX_ATTEMPTS=3

# ── PostgreSQL (Step 3) ────────────────────────────────────────────────────────
# Cloud options: Supabase, Neon, Railway, Render
# Format: postgresql://user:password@host:port/dbname
DATABASE_URL=postgresql://user:password@host:5432/jobfinder

# ── AWS S3 (Resume storage) ──────────────────────────────────────────────────
# Defaults in code:
# AWS_REGION=us-east-1
# AWS_S3_BUCKET=job-finder-resume-s3-bucket
# Set credentials for IAM user with bucket access.
AWS_REGION=us-east-1
AWS_S3_BUCKET=job-finder-resume-s3-bucket
AWS_ACCESS_KEY_ID=your_aws_access_key_id
AWS_SECRET_ACCESS_KEY=your_aws_secret_access_key

# ── Scraper settings (Step 3) ─────────────────────────────────────────────────
# Comma-separated list of search terms
SCRAPE_KEYWORDS=python engineer,backend developer,software engineer
# Location filter — use "remote" or a city name
SCRAPE_LOCATION=remote
# How often the scheduler runs (hours, supports decimals e.g. 0.5)
SCRAPE_INTERVAL_HOURS=4
# Comma-separated source names to enable (leave blank = all)
# Options: hn, greenhouse, linkedin
SCRAPE_SOURCES=
# Max results fetched per source per run
SCRAPE_MAX_PER_SOURCE=50

# ── Notifications (Step 9) ───────────────────────────────────────────────────
# Daily digest scheduler configuration
NOTIFY_TIMEZONE=Asia/Kolkata
NOTIFY_DAILY_TIME=09:00
NOTIFY_TOP_K=10

# Strong match thresholds (both are enforced)
NOTIFY_MIN_TOP_APPLICANT=85
NOTIFY_MIN_RANKING_SCORE=0.85

# Optional ranking location hints (comma-separated)
NOTIFY_PREFERRED_LOCATIONS=remote

# Candidate scan size
NOTIFY_CANDIDATE_LIMIT=5000

# Salary normalization for mixed currencies (INR -> USD conversion)
SALARY_USD_TO_INR=100.0

# Email channel provider: smtp | mailgun
NOTIFY_EMAIL_PROVIDER=smtp

# Email sender/recipient
NOTIFY_EMAIL_FROM=you@example.com
NOTIFY_EMAIL_TO=you@example.com

# Email channel (SMTP)
NOTIFY_EMAIL_SMTP_HOST=smtp.gmail.com
NOTIFY_EMAIL_SMTP_PORT=587
# For SMTP over SSL (e.g., Gmail 465), set true and port 465
NOTIFY_EMAIL_SMTP_SSL=false
NOTIFY_EMAIL_USE_TLS=true
NOTIFY_EMAIL_SMTP_USER=you@example.com
NOTIFY_EMAIL_SMTP_PASSWORD=your_app_password_here

# Email channel (Mailgun API)
# Free plan/trial availability varies by region/account.
# Create domain + API key at https://www.mailgun.com/
NOTIFY_MAILGUN_DOMAIN=mg.example.com
NOTIFY_MAILGUN_API_KEY=key-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
# us or eu
NOTIFY_MAILGUN_REGION=us
